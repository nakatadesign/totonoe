# totonoe 環境変数の雛形
# このファイルを .env にコピーして値を設定してください。
#
#   cp .env.example .env
#
# totonoe のスクリプト（common.sh）はリポジトリルートの .env を自動で読み込みます。
# 手動で source .env を実行する必要はありません。

# --- Gemini（fallback / shadow 用 provider） ---

# Gemini API キー（fallback / shadow を使う場合に必要）
# Codex-only の通常運用では未設定でも動作します
# https://aistudio.google.com/apikey から取得してください
GEMINI_API_KEY=

# Gemini モデル名（省略時: gemini-2.5-flash-lite）
# gemini-2.5-pro は project / tier によって free tier で使えない場合があるため、
# totonoe では fallback / shadow 用の軽量な既定値として flash-lite を採用しています
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Codex ---

# Codex モデル名（監査ログ記録用）
# codex exec の --model オプションには渡しません
CODEX_MODEL=gpt-5-codex

# --- クールダウン ---

# Codex 失敗時の Gemini フォールバック冷却時間（秒）
# 連続失敗ごとに倍増し、最大 7200 秒（2時間）で上限
AI_PROVIDER_COOLDOWN_BASE_SECONDS=1800
