# totonoe 環境変数の雛形
# このファイルを .env にコピーして値を設定してください。
#
#   cp .env.example .env
#
# totonoe のスクリプトは .env を自動で読み込みません。
# 以下のいずれかの方法で環境変数として読み込んでください。
#
#   source .env                      # 手動で読み込む
#   direnv allow                     # direnv を使う場合（.envrc から source）
#   export $(grep -v '^#' .env | xargs)  # 一括 export

# --- Gemini（fallback / shadow 用 provider） ---

# Gemini API キー（必須）
# https://aistudio.google.com/apikey から取得してください
GEMINI_API_KEY=

# Gemini モデル名（省略時: gemini-2.5-pro）
GEMINI_MODEL=gemini-2.5-pro

# --- Codex ---

# Codex モデル名（監査ログ記録用）
# codex exec の --model オプションには渡しません
CODEX_MODEL=gpt-5-codex

# --- クールダウン ---

# Codex 失敗時の Gemini フォールバック冷却時間（秒）
# 連続失敗ごとに倍増し、最大 7200 秒（2時間）で上限
AI_PROVIDER_COOLDOWN_BASE_SECONDS=1800
