{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recommendation",
    "reason",
    "must_fix",
    "can_defer",
    "next_step",
    "engineer_type"
  ],
  "properties": {
    "recommendation": {
      "type": "string",
      "enum": ["fix", "continue", "done", "human"]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "must_fix": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "can_defer": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_step": {
      "type": "string",
      "minLength": 1
    },
    "engineer_type": {
      "type": "string",
      "enum": ["security", "test", "performance", "refactor", "generic"],
      "description": "Analyst が推奨する Engineer の専門種別。recommendation が fix のとき設定される。"
    },
    "spot_check_required": {
      "type": "boolean"
    }
  }
}
